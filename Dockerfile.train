# Solidity Vulnerability Detection — Training Dockerfile
#
# Multi-stage build:
#   - base:  Core env + scoring + skyrl-gym
#   - sft:   TRL-based SFT training
#   - grpo:  SkyRL Online RL (RLOO/DAPO)
#
# Build:
#   docker build -t solidity-train:sft  --target sft  -f Dockerfile.train .
#   docker build -t solidity-train:grpo --target grpo -f Dockerfile.train .
#
# Quick test (no GPU needed):
#   docker build -t solidity-train:base --target base -f Dockerfile.train .
#   docker run --rm solidity-train:base python3 test_smoke.py

# ============================================================
# Base stage
# ============================================================
FROM nvcr.io/nvidia/pytorch:25.11-py3 AS base

ENV DEBIAN_FRONTEND=noninteractive \
    PYTHONUNBUFFERED=1 \
    HF_HUB_ENABLE_HF_TRANSFER=1

WORKDIR /workspace/hud

# System deps
RUN apt-get update && apt-get install -y --no-install-recommends \
    git curl ca-certificates jq \
    && rm -rf /var/lib/apt/lists/*

# Python deps (base)
RUN pip install --no-cache-dir \
    skyrl-gym \
    anthropic \
    openai \
    python-dotenv \
    pyyaml \
    jinja2

# Copy TrajGym source (for formatters, parsing, training CLI)
COPY open-trajectory-gym /workspace/open-trajectory-gym
RUN pip install --no-cache-dir -e /workspace/open-trajectory-gym 2>/dev/null || \
    echo "TrajGym base install (partial deps ok)"

ENV PYTHONPATH=/workspace/open-trajectory-gym/src:/workspace/hud:$PYTHONPATH

# Copy project source
COPY env.py run_eval_standalone.py skyrl_env.py \
     prepare_skyrl_data.py training.yaml \
     slime_generate.py convert_traces_for_sft.py \
     run_sft.py \
     /workspace/hud/

# Copy smoke test
COPY test_smoke.py /workspace/hud/

# Data is volume-mounted at runtime
# /workspace/hud/data/scenarios.json
# /workspace/hud/data/skyrl_prompts.jsonl
# /workspace/hud/data/slime_sft_traces.jsonl

CMD ["python3", "test_smoke.py"]

# ============================================================
# SFT stage — TRL + transformers>=5.2 for Qwen3.5
# ============================================================
FROM base AS sft

RUN pip install --no-cache-dir \
    "trl>=0.16.0" \
    "peft>=0.15.0" \
    "accelerate>=1.4.0" \
    "datasets>=3.0.0" \
    "bitsandbytes>=0.45.0" \
    "transformers>=5.2.0" \
    "huggingface-hub>=1.4" \
    "hf_transfer"

CMD ["python3", "-c", "from trl import SFTTrainer; print('SFT ready')"]

# ============================================================
# GRPO stage — Official SkyRL Docker base
# ============================================================
FROM novaskyai/skyrl-train-ray-2.51.1-py3.12-cu12.8 AS grpo

WORKDIR /workspace

# Install SkyRL from source: skyrl-gym (env layer) + skyrl (training framework)
RUN git clone --depth 1 https://github.com/novasky-ai/SkyRL.git /workspace/SkyRL && \
    pip install --no-cache-dir --force-reinstall /workspace/SkyRL/skyrl-gym && \
    pip install --no-cache-dir -e "/workspace/SkyRL[fsdp]" 2>/dev/null || \
    pip install --no-cache-dir -e /workspace/SkyRL || true

# Only compile for H100 (sm90) — skips sm80/sm100/sm120, 4x faster
ENV TORCH_CUDA_ARCH_LIST="9.0"

# Install ALL deps that Ray workers will need (runtime pip install doesn't reach them)
RUN pip install --no-cache-dir \
    "transformers>=5.2.0" "huggingface-hub>=1.4" \
    datasets tokenizers \
    jaxtyping beartype torchdata "scipy>=1.14" \
    flash-attn wandb \
    anthropic openai python-dotenv pyyaml jinja2 peft accelerate \
    omegaconf hydra-core colorama tqdm loguru pandas pyarrow && \
    pip install --no-cache-dir vllm --extra-index-url https://wheels.vllm.ai/nightly || \
    pip install --no-cache-dir "vllm>=0.16.0" || true

WORKDIR /workspace/hud

# Copy project source
COPY env.py run_eval_standalone.py skyrl_env.py \
     prepare_skyrl_data.py training.yaml \
     run_skyrl_train.py run_online_rl.py \
     test_grpo.py \
     /workspace/hud/

# Copy TrajGym source (for config builder, formatters)
COPY open-trajectory-gym /workspace/open-trajectory-gym
RUN pip install --no-cache-dir /workspace/open-trajectory-gym 2>/dev/null || true

ENV PYTHONPATH=/workspace/open-trajectory-gym/src:/workspace/hud:$PYTHONPATH

CMD ["python3", "-c", "from skyrl_gym.envs import register; from skyrl_env import SolidityVulnEnv; print('GRPO ready')"]
